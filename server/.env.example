# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys.
#
# Version 2 uses Gradium STT by default, optional NVIDIA Parakeet STT,
# Nemotron for LLM, and Gradium for TTS.
# Version 1 additionally uses OPENAI_API_KEY.

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=Eu9iL_CYe8N-Gkx_

# OpenAI (Version 1 LLM)
OPENAI_API_KEY=

# STT provider. Leave as gradium for the most stable path. Set to parakeet
# for NVIDIA's multilingual Parakeet websocket STT.
STT_PROVIDER=gradium
PARAKEET_STT_URL=
NVIDIA_ASR_URL=ws://44.241.251.184:8080

# NVIDIA/Nemotron Version 2
NEMOTRON_LLM_URL=http://nemotron-fleet-alb-1322439314.us-west-2.elb.amazonaws.com/v1
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_LLM_API_KEY=EMPTY
NEMOTRON_ENABLE_THINKING=false

# Optional WebRTC video avatar layer. Defaults to audio-only so Cekura,
# Twilio, and the self-improvement harness keep the existing bot behavior.
AVATAR_PROVIDER=none
AVATAR_VIDEO_WIDTH=1280
AVATAR_VIDEO_HEIGHT=720
AVATAR_VIDEO_FRAMERATE=30

# Tavus avatar renderer (used only when AVATAR_PROVIDER=tavus)
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=pipecat-stream

# Optional Simli fallback (requires adding the pipecat Simli extra)
SIMLI_API_KEY=
SIMLI_FACE_ID=

# Local development environment. Set to "production" in production to disable verbose logging and enable any production-only features.
ENV=local
